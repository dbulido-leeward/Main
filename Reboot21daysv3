# 1. Get the operating system boot time and calculate uptime
$os = Get-CimInstance Win32_OperatingSystem
$uptime = (Get-Date) - $os.LastBootUpTime

# 2. Define the threshold (0 for testing)
$threshold = 0

if ($uptime.Days -ge $threshold) {

    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing

    # --- FORM SETUP ---
    $form = New-Object System.Windows.Forms.Form
    $form.Text = "Critical System Maintenance"
    $form.Size = New-Object System.Drawing.Size(450, 320)
    $form.StartPosition = "CenterScreen"
    $form.TopMost = $true
    $form.FormBorderStyle = "FixedDialog"
    $form.MaximizeBox = $false

    # Icon
    $icon = New-Object System.Windows.Forms.PictureBox
    $icon.Size = New-Object System.Drawing.Size(48,48)
    $icon.Location = New-Object System.Drawing.Point(20,20)
    $icon.Image = [System.Drawing.SystemIcons]::Warning.ToBitmap()
    $form.Controls.Add($icon)

    # Main Label
    $label = New-Object System.Windows.Forms.Label
    $label.Location = New-Object System.Drawing.Point(85, 20)
    $label.Size = New-Object System.Drawing.Size(330, 80)
    $label.Text = "System Uptime: $($uptime.Days) days.`n`nA forced restart is required for security updates. Please save all work now."
    $label.Font = New-Object System.Drawing.Font("Segoe UI", 10)
    $form.Controls.Add($label)

    # Countdown Label
    $countdownLabel = New-Object System.Windows.Forms.Label
    $countdownLabel.Location = New-Object System.Drawing.Point(85, 110)
    $countdownLabel.Size = New-Object System.Drawing.Size(330, 40)
    $countdownLabel.Font = New-Object System.Drawing.Font("Segoe UI", 11, [System.Drawing.FontStyle]::Bold)
    $countdownLabel.ForeColor = "Red"
    $form.Controls.Add($countdownLabel)

    # --- BUTTONS ---
    $restartBtn = New-Object System.Windows.Forms.Button
    $restartBtn.Location = New-Object System.Drawing.Point(85, 180)
    $restartBtn.Size = New-Object System.Drawing.Size(140, 40)
    $restartBtn.Text = "Restart Now"
    $restartBtn.BackColor = "LightCoral"
    
    $restartBtn.Add_Click({ 
        $restartBtn.Enabled = $false
        $cancelBtn.Enabled = $false
        
        # 1. TRIGGER WINDOWS SHUTDOWN IMMEDIATELY (FORCE MODE)
        # /r = restart, /f = FORCE, /t = time, /c = comment
        # Using cmd /c is often more reliable for legacy exe calls in PS
        cmd.exe /c "shutdown.exe /r /f /t 120 /c `"Mandatory Reboot: System will restart in 120 seconds. Please save your work.`""

        # 2. START VISUAL TIMER
        $script:secondsLeft = 120
        $script:timer = New-Object System.Windows.Forms.Timer
        $script:timer.Interval = 1000 
        $script:timer.Add_Tick({
            $script:secondsLeft--
            $countdownLabel.Text = "FORCED RESTART IN: $($script:secondsLeft)s"
            
            if ($script:secondsLeft -le 0) {
                $script:timer.Stop()
                $form.Close()
            }
        })
        $script:timer.Start()
    })
    $form.Controls.Add($restartBtn)

    $cancelBtn = New-Object System.Windows.Forms.Button
    $cancelBtn.Location = New-Object System.Drawing.Point(240, 180)
    $cancelBtn.Size = New-Object System.Drawing.Size(130, 40)
    $cancelBtn.Text = "Cancel"
    
    $cancelBtn.Add_Click({ 
        # Attempt to abort the shutdown if they click cancel
        cmd.exe /c "shutdown.exe /a"
        $form.Close() 
    })
    $form.Controls.Add($cancelBtn)

    $form.ShowDialog() | Out-Null

}
